---
import Layout from "../../layouts/Layout.astro";
import CloseContact from "../../components/CloseContact.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("resources");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Layout
  title={`${post.data.title} — Resources`}
  description={post.data.description}
  image={post.data.cover}
>
  <!-- Reading progress bar (functional; stays under reduced motion) -->
  <div class="reading-progress" aria-hidden="true">
    <span class="reading-progress-fill" data-progress></span>
  </div>

  <!-- Cover hero -->
  <header class="post-hero relative isolate overflow-hidden">
    <div class="post-hero-cover absolute inset-0 z-0">
      <img
        class="post-cover-img h-full w-full object-cover"
        src={post.data.cover}
        alt=""
        loading="eager"
        width="1600"
        height="900"
        data-cover-img
      />
      <span class="post-hero-tint absolute inset-0"></span>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl px-5 pb-12 pt-24 sm:px-8 md:pb-16 md:pt-32">
      <nav aria-label="Breadcrumb" class="text-xs text-white/75" data-reveal>
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <li><a href="/" class="transition-colors hover:text-white">Home</a></li>
          <li class="text-white/40">/</li>
          <li><a href="/resources" class="transition-colors hover:text-white">Resources</a></li>
          <li class="text-white/40">/</li>
          <li class="text-white/60">{post.data.title}</li>
        </ol>
      </nav>

      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm" data-reveal data-reveal-delay="1">
        <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
          {post.data.category}
        </span>
        <time class="text-white/80" datetime={post.data.publishDate.toISOString()}>
          {fmtDate(post.data.publishDate)}
        </time>
        {post.data.readingTime && (
          <>
            <span class="text-white/40" aria-hidden="true">·</span>
            <span class="text-white/80">{post.data.readingTime}</span>
          </>
        )}
      </div>

      <h1
        class="mt-4 font-heading text-3xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl"
        data-reveal
        data-reveal-delay="2"
      >
        {post.data.title}
      </h1>
    </div>
  </header>

  <!-- Body -->
  <article id="post-body" class="bg-white py-14 md:py-20">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <div class="prose" data-reveal>
        <Content />
      </div>

      <div class="mt-12 border-t border-line pt-8" data-reveal>
        <a href="/resources" class="inline-flex items-center gap-2 font-semibold text-azure transition-colors hover:text-navy">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12h-14" />
            <path d="M11 18l-6 -6l6 -6" />
          </svg>
          Back to Resources
        </a>
      </div>
    </div>
  </article>

  <CloseContact />
</Layout>

<style>
  /* Fixed reading-progress bar above everything. */
  .reading-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 60;
    background: transparent;
    pointer-events: none;
  }
  .reading-progress-fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(to right, var(--sky), var(--azure) 55%, var(--navy));
  }

  .post-hero {
    background: var(--ink);
  }
  .post-hero-tint {
    background: linear-gradient(
      160deg,
      rgba(10, 31, 77, 0.62),
      rgba(3, 57, 179, 0.55) 55%,
      rgba(10, 31, 77, 0.78)
    );
  }

  /* Reading layout: constrained measure (~68ch), strong hierarchy. */
  .prose {
    max-width: 68ch;
    color: var(--body-text);
    font-size: 1.0625rem;
    line-height: 1.8;
  }
  .prose :global(h2) {
    font-family: var(--font-heading);
    color: var(--ink);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-family: var(--font-heading);
    color: var(--ink);
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) { margin: 1.1rem 0; }
  .prose :global(ul),
  .prose :global(ol) { margin: 1.1rem 0; padding-left: 1.3rem; }
  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(li) { margin: 0.4rem 0; }
  .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .prose :global(a) {
    color: var(--azure);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(blockquote) {
    margin: 1.75rem 0;
    border-left: 3px solid var(--azure);
    padding: 0.25rem 0 0.25rem 1.1rem;
    color: var(--body-text);
    font-style: italic;
  }
</style>

<script>
  // Reading progress (functional, always on) + cover parallax (motion-OK only).
  // Isolated in try/catch; never blocks the global reveal system.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { prefersReducedMotion } from "../../scripts/motion";

  try {
    gsap.registerPlugin(ScrollTrigger);
    const fill = document.querySelector<HTMLElement>("[data-progress]");
    const body = document.getElementById("post-body");

    if (fill && body) {
      ScrollTrigger.create({
        trigger: body,
        start: "top top",
        end: "bottom bottom",
        onUpdate: (self) => gsap.set(fill, { scaleX: self.progress }),
      });
    }

    if (!prefersReducedMotion()) {
      const cover = document.querySelector<HTMLElement>("[data-cover-img]");
      const hero = document.querySelector<HTMLElement>(".post-hero");
      if (cover && hero) {
        gsap.set(cover, { scale: 1.12, transformOrigin: "center" });
        gsap.fromTo(
          cover,
          { yPercent: -5 },
          {
            yPercent: 6,
            ease: "none",
            scrollTrigger: { trigger: hero, start: "top top", end: "bottom top", scrub: true },
          },
        );
      }
    }
  } catch (err) {
    console.error("[post] progress/parallax failed (non-fatal)", err);
  }
</script>
