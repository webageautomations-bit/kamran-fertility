---
import Layout from "../../layouts/Layout.astro";
import CloseContact from "../../components/CloseContact.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("resources");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Layout title={`${post.data.title} — Resources`} description={post.data.description}>
  <article class="bg-white pb-8 pt-16 md:pt-24">
    <div class="mx-auto max-w-2xl px-5 sm:px-8">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="text-sm text-body" data-reveal>
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <li><a href="/" class="transition-colors hover:text-azure">Home</a></li>
          <li class="text-line">/</li>
          <li><a href="/resources" class="transition-colors hover:text-azure">Resources</a></li>
          <li class="text-line">/</li>
          <li class="text-ink/70">{post.data.title}</li>
        </ol>
      </nav>

      <!-- Header -->
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm" data-reveal>
        <span class="inline-flex items-center rounded-full bg-azure/10 px-3 py-1 text-xs font-semibold text-azure">
          {post.data.category}
        </span>
        <time class="text-body/70" datetime={post.data.publishDate.toISOString()}>
          {fmtDate(post.data.publishDate)}
        </time>
        {post.data.readingTime && (
          <>
            <span class="text-body/40" aria-hidden="true">·</span>
            <span class="text-body/70">{post.data.readingTime}</span>
          </>
        )}
      </div>

      <h1
        class="mt-4 font-heading text-3xl font-extrabold leading-[1.1] tracking-tight text-ink sm:text-4xl"
        data-reveal
        data-reveal-delay="1"
      >
        {post.data.title}
      </h1>

      <!-- Body -->
      <div class="prose mt-8" data-reveal data-reveal-delay="2">
        <Content />
      </div>
    </div>
  </article>

  <CloseContact />
</Layout>

<style>
  /* Reading layout: constrained measure (~68ch), strong hierarchy. */
  .prose {
    max-width: 68ch;
    color: var(--body-text);
    font-size: 1.0625rem;
    line-height: 1.8;
  }
  .prose :global(h2) {
    font-family: var(--font-heading);
    color: var(--ink);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-family: var(--font-heading);
    color: var(--ink);
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) {
    margin: 1.1rem 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.1rem 0;
    padding-left: 1.3rem;
  }
  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(li) {
    margin: 0.4rem 0;
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .prose :global(a) {
    color: var(--azure);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(blockquote) {
    margin: 1.75rem 0;
    border-left: 3px solid var(--azure);
    padding: 0.25rem 0 0.25rem 1.1rem;
    color: var(--body-text);
    font-style: italic;
  }
</style>
