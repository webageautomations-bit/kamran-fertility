---
const whatsappHref = "https://wa.me/923148432789";
const phoneDisplay = "+92 314 8432789";
const phoneHref = "tel:+923148432789";

const locations = [
  "Rasheed Hospital — Main Boulevard, DHA Defence, Lahore",
  "TAMC — M.M. Alam Road, Lahore",
  "Shahnaz Hospital — Shalamar Link Road, Lahore 54000",
];

// TODO: confirm exact pin.
const mapSrc =
  "https://www.google.com/maps?q=Rasheed+Hospital,+Main+Boulevard,+DHA+Defence,+Lahore&output=embed";
---

<section id="contact" class="close relative scroll-mt-20 overflow-hidden pb-20 pt-32 md:pb-24 md:pt-36">
  <!-- Clean shallow two-layer wave (FAQ #F4F9FE over the navy). -->
  <div class="pointer-events-none absolute inset-x-0 top-0 leading-[0]" aria-hidden="true">
    <svg
      class="wave-back absolute inset-x-0 top-0 h-[56px] w-[112%] -translate-x-[6%] sm:h-[72px]"
      viewBox="0 0 1440 100"
      preserveAspectRatio="none"
      fill="none"
    >
      <path d="M0,54 C480,18 960,18 1440,54 L1440,0 L0,0 Z" fill="#cfe0f5"></path>
    </svg>
    <svg
      class="absolute inset-x-0 top-0 h-[56px] w-full sm:h-[72px]"
      viewBox="0 0 1440 100"
      preserveAspectRatio="none"
      fill="none"
    >
      <path d="M0,42 C480,8 960,8 1440,42 L1440,0 L0,0 Z" fill="#F4F9FE"></path>
    </svg>
  </div>

  <div class="relative z-10 mx-auto grid max-w-6xl gap-12 px-5 sm:px-8 lg:grid-cols-[48fr_52fr] lg:items-center lg:gap-16">
    <!-- LEFT — the close -->
    <div data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky">
        Take the next step
      </p>
      <h2 class="mt-3 t-h2 text-white">
        Whatever stage you're at, you won't be rushed — or judged.
      </h2>
      <p class="mt-5 measure text-base text-white/80">
        Message Dr. Kamran's clinic on WhatsApp and we'll guide you from there.
        Fees are explained up front, and there's no obligation to proceed with
        anything that doesn't feel right for you.
      </p>

      <div class="mt-8">
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener"
          data-magnetic
          class="inline-flex items-center justify-center gap-2.5 rounded-full bg-white px-8 py-4 text-base font-semibold text-navy shadow-[var(--shadow-soft)] transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.099zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
            ></path>
          </svg>
          Message us on WhatsApp
        </a>
        <p class="mt-4 text-sm text-white/70">We usually reply the same day.</p>
      </div>
    </div>

    <!-- RIGHT — clinic details on a translucent glass panel -->
    <div
      class="rounded-[var(--r-lg)] border border-white/15 bg-white/[0.06] p-6 backdrop-blur-sm sm:p-8"
      data-reveal
      data-reveal-delay="1"
    >
      <h3 class="font-heading text-xl font-bold text-white">Visit us</h3>

      <ul class="mt-5 space-y-3.5">
        {
          locations.map((loc) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-sky"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" />
                <path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z" />
              </svg>
              <span class="text-sm leading-relaxed text-white/85">{loc}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.16em] text-sky">
            Opening hours
          </h4>
          <p class="mt-2 text-sm text-white/85">Mon–Sat: 11:00am – 9:00pm</p>
          <p class="text-sm text-white/85">Sun &amp; public holidays: Closed</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.16em] text-sky">
            Phone / WhatsApp
          </h4>
          <p class="mt-2 text-sm">
            <a href={phoneHref} class="font-semibold text-white underline decoration-sky/60 underline-offset-4 transition-colors hover:text-sky">
              {phoneDisplay}
            </a>
          </p>
          <p class="mt-1 text-sm">
            <a
              href={whatsappHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sky transition-opacity hover:opacity-80"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.099zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
                ></path>
              </svg>
              Chat on WhatsApp
            </a>
          </p>
        </div>
      </div>

      <div class="mt-6 overflow-hidden rounded-[var(--r-lg)] border border-white/15">
        <iframe
          title="Map — Rasheed Hospital, Main Boulevard, DHA Defence, Lahore"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-56 w-full border-0"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  /* Premium navy depth: diagonal gradient + off-centre upper-left light +
     edge vignette. All logo blues. */
  .close {
    background:
      radial-gradient(
        130% 120% at 50% 50%,
        transparent 52%,
        rgba(3, 16, 52, 0.5) 100%
      ),
      radial-gradient(
        90% 80% at 18% 12%,
        rgba(102, 221, 255, 0.3) 0%,
        rgba(74, 133, 235, 0.16) 32%,
        transparent 62%
      ),
      linear-gradient(135deg, #0a3bb0 0%, #0a1f4d 60%, #061536 100%);
  }

  .wave-back {
    animation: wave-drift 18s ease-in-out infinite;
  }
  @keyframes wave-drift {
    0%, 100% { transform: translateX(-6%); }
    50% { transform: translateX(-3%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wave-back { animation: none; }
  }
</style>

<script>
  // Magnetic pull on the single primary WhatsApp button — desktop, fine-pointer,
  // motion-OK only. Transform-only, so the link always remains clickable.
  // Isolated in try/catch; cannot affect the global reveal system.
  import { gsap } from "gsap";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  try {
    if (!prefersReducedMotion()) {
      const mm = gsap.matchMedia();
      mm.add("(min-width: 1024px) and (hover: hover) and (pointer: fine)", () => {
        const btn = document.querySelector<HTMLAnchorElement>(".close [data-magnetic]");
        if (!btn) return;
        const xTo = gsap.quickTo(btn, "x", { duration: 0.5, ease: EASE });
        const yTo = gsap.quickTo(btn, "y", { duration: 0.5, ease: EASE });
        const onMove = (e: PointerEvent) => {
          const r = btn.getBoundingClientRect();
          xTo((e.clientX - (r.left + r.width / 2)) * 0.35);
          yTo((e.clientY - (r.top + r.height / 2)) * 0.35);
        };
        const onLeave = () => {
          xTo(0);
          yTo(0);
        };
        btn.addEventListener("pointermove", onMove);
        btn.addEventListener("pointerleave", onLeave);
        return () => {
          btn.removeEventListener("pointermove", onMove);
          btn.removeEventListener("pointerleave", onLeave);
          gsap.set(btn, { x: 0, y: 0 });
        };
      });
    }
  } catch (err) {
    console.error("[close] magnetic init failed (non-fatal)", err);
  }
</script>
