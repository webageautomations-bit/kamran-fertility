---
const cards = [
  {
    title: "Trying to conceive",
    body: "Months of trying, or unsure when to seek help. We start with clarity — not procedures.",
    icon: "heart-handshake",
  },
  {
    title: "Men's fertility & reproductive health",
    body: "Sperm health, hormones, infections — assessed with full confidentiality and zero stigma.",
    icon: "user-check",
  },
  {
    title: "Cycle & hormone concerns",
    body: "Irregular cycles, suspected PCOS, thyroid or ovulation issues — in women or men.",
    icon: "heartbeat",
  },
];
---

<!-- Base colour only; the hero's ambient layer bleeds over the top of this
     section and dissolves into #F4F9FE, so there is no boundary line.
     Section stays static so the hero's positioned ambient paints over this
     background; only the content below is elevated above it. -->
<section class="bg-ice">
  <div class="relative z-10 mx-auto max-w-7xl px-5 pb-20 pt-24 sm:px-8 md:pb-28 md:pt-28">
    <!-- Plain header -->
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow">
        Where we begin
      </p>
      <h2 class="mt-3 t-h2 text-ink">
        Fertility concerns we commonly support
      </h2>
    </div>

    <!-- Cards -->
    <div
      class="mt-14 grid grid-cols-1 gap-6 sm:[grid-template-columns:repeat(auto-fit,minmax(180px,1fr))]"
    >
      {
        cards.map((card, i) => (
          <article
            class="hover-lift group relative overflow-hidden rounded-[var(--r-md)] border border-line bg-white p-7 shadow-[var(--shadow-soft)]"
            data-reveal
            data-reveal-delay={i + 1}
          >
            {/* Top accent bar */}
            <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-sky to-azure transition-transform duration-300 group-hover:scale-x-100" />

            {/* Icon tile — scales & shifts toward azure on card hover */}
            <div class="flex h-14 w-14 items-center justify-center rounded-[var(--r-sm)] bg-gradient-to-br from-ice to-[#cfe4ff] text-navy transition-all duration-300 group-hover:scale-105 group-hover:text-azure">
              <svg
                class="c-icon h-7 w-7"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {card.icon === "heart-handshake" && (
                  <>
                    <path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572" />
                    <path d="M12 6l-3.293 3.293a1 1 0 0 0 0 1.414l.543 .543c.69 .69 1.81 .69 2.5 0l1 -1a3.182 3.182 0 0 1 4.5 0l2.25 2.25" />
                    <path d="M12.5 15.5l2 2" />
                    <path d="M15 13l2 2" />
                  </>
                )}
                {card.icon === "user-check" && (
                  <>
                    <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" />
                    <path d="M6 21v-2a4 4 0 0 1 4 -4h4" />
                    <path d="M15 19l2 2l4 -4" />
                  </>
                )}
                {card.icon === "heartbeat" && (
                  <>
                    <path d="M19.5 13.572l-7.5 7.428l-2.896 -2.868m-6.117 -8.104a5 5 0 0 1 9.013 -3.022a5 5 0 1 1 7.5 6.572" />
                    <path d="M3 13h2l2 3l2 -6l1 3h3" />
                  </>
                )}
              </svg>
            </div>

            <h3 class="mt-5 font-heading text-lg font-bold text-ink">
              {card.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-body">{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Icon micro-interaction: ONE subtle pulse on card hover (motion-OK only). */
  @media (prefers-reduced-motion: no-preference) {
    .c-icon {
      transition: transform 0.25s ease;
    }
    .group:hover .c-icon {
      animation: c-pulse 0.28s ease;
    }
    @keyframes c-pulse {
      0% { transform: scale(1); }
      45% { transform: scale(1.14); }
      100% { transform: scale(1); }
    }
  }
</style>
