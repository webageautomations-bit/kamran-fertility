---
const whatsappHref = "https://wa.me/923148432789";
---

<section class="cta relative overflow-hidden bg-gradient-to-r from-navy to-azure pb-20 pt-32 md:pb-24 md:pt-36">
  <!-- Clean shallow two-layer wave (FAQ #F4F9FE over the navy). The back tint
       layer reads as intentional depth and drifts slowly; both share the same
       gentle, low-amplitude curve so they never look misaligned. -->
  <div class="pointer-events-none absolute inset-x-0 top-0 leading-[0]" aria-hidden="true">
    <svg
      class="wave-back absolute inset-x-0 top-0 h-[56px] w-[112%] -translate-x-[6%] sm:h-[72px]"
      viewBox="0 0 1440 100"
      preserveAspectRatio="none"
      fill="none"
    >
      <path d="M0,54 C480,18 960,18 1440,54 L1440,0 L0,0 Z" fill="#cfe0f5"></path>
    </svg>
    <svg
      class="absolute inset-x-0 top-0 h-[56px] w-full sm:h-[72px]"
      viewBox="0 0 1440 100"
      preserveAspectRatio="none"
      fill="none"
    >
      <path d="M0,42 C480,8 960,8 1440,42 L1440,0 L0,0 Z" fill="#F4F9FE"></path>
    </svg>
  </div>

  <!-- Faint cross-mark watermark (one of only two on the page). -->
  <img
    src="/favicon.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-10 -right-8 z-0 w-72 select-none opacity-[0.06] brightness-0 invert sm:w-96"
  />

  <div class="relative z-10 mx-auto max-w-3xl px-5 text-center sm:px-8">
    <h2 class="t-h2 text-white" data-reveal>
      Ready to book a consultation?
    </h2>
    <p class="mx-auto mt-5 measure text-base text-white/85 [margin-inline:auto]" data-reveal data-reveal-delay="1">
      Message us on WhatsApp and we'll guide you from there — fees explained up
      front, and no obligation to proceed with anything that doesn't feel right
      for you.
    </p>
    <p class="mt-4 font-heading text-base font-bold text-white" data-reveal data-reveal-delay="2">
      No marketing add-ons. No hidden fees. No pressure.
    </p>

    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row" data-reveal data-reveal-delay="3">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        data-magnetic
        class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3.5 text-base font-semibold text-navy shadow-[var(--shadow-soft)] transition-transform duration-200 hover:-translate-y-0.5"
      >
        Book a consultation
      </a>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-full border border-white/60 px-7 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:bg-white/10"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.099zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
          ></path>
        </svg>
        Speak to us first
      </a>
    </div>

    <p class="mt-5 text-sm text-white/70" data-reveal data-reveal-delay="4">
      Ask us anything about your situation — no obligation.
    </p>
  </div>
</section>

<style>
  /* Back wave drifts slowly; skipped under reduced motion. */
  .wave-back {
    animation: wave-drift 18s ease-in-out infinite;
  }
  @keyframes wave-drift {
    0%, 100% { transform: translateX(-6%); }
    50% { transform: translateX(-3%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wave-back {
      animation: none;
    }
  }
</style>

<script>
  // Magnetic pull on the primary WhatsApp button — desktop, fine-pointer,
  // motion-OK only. Transform-only, so the link always remains clickable.
  import { gsap } from "gsap";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  if (!prefersReducedMotion()) {
    const mm = gsap.matchMedia();
    mm.add("(min-width: 1024px) and (hover: hover) and (pointer: fine)", () => {
      const btn = document.querySelector<HTMLAnchorElement>(".cta [data-magnetic]");
      if (!btn) return;
      const xTo = gsap.quickTo(btn, "x", { duration: 0.5, ease: EASE });
      const yTo = gsap.quickTo(btn, "y", { duration: 0.5, ease: EASE });
      const onMove = (e: PointerEvent) => {
        const r = btn.getBoundingClientRect();
        xTo((e.clientX - (r.left + r.width / 2)) * 0.35);
        yTo((e.clientY - (r.top + r.height / 2)) * 0.35);
      };
      const onLeave = () => {
        xTo(0);
        yTo(0);
      };
      btn.addEventListener("pointermove", onMove);
      btn.addEventListener("pointerleave", onLeave);
      return () => {
        btn.removeEventListener("pointermove", onMove);
        btn.removeEventListener("pointerleave", onLeave);
        gsap.set(btn, { x: 0, y: 0 });
      };
    });
  }
</script>
