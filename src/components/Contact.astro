---
const phoneDisplay = "+92 314 8432789";
const phoneHref = "tel:+923148432789";
const whatsappHref = "https://wa.me/923148432789";

const locations = [
  "Rasheed Hospital — Main Boulevard, DHA Defence, Lahore",
  "TAMC — M.M. Alam Road, Lahore",
  "Shahnaz Hospital — Shalamar Link Road, Lahore 54000",
];

// TODO: confirm exact pin + decide whether to show all three locations.
const mapSrc =
  "https://www.google.com/maps?q=Rasheed+Hospital,+Main+Boulevard,+DHA+Defence,+Lahore&output=embed";
---

<!-- Clean white -- the dark CTA band ends on a crisp edge here, never a fade. -->
<section class="relative bg-white py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow" data-reveal>
        Contact & location
      </p>
      <h2 class="mt-3 t-h2 text-ink" data-reveal data-reveal-delay="1">
        Visit or get in touch
      </h2>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-2 lg:items-stretch">
      <!-- LEFT — details -->
      <div
        class="rounded-[var(--r-lg)] border border-line bg-ice p-7 shadow-[var(--shadow-soft)] sm:p-9"
        data-reveal
      >
        <h3 class="font-heading text-lg font-bold text-ink">Clinic locations</h3>
        <ul class="mt-5 space-y-4" data-stagger>
          {
            locations.map((loc) => (
              <li class="flex items-start gap-3" data-reveal>
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-azure"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" />
                  <path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z" />
                </svg>
                <span class="text-sm leading-relaxed text-body">{loc}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mt-8 font-heading text-lg font-bold text-ink">Opening hours</h3>
        <ul class="mt-4 space-y-1 text-sm text-body">
          <li><span class="font-medium text-ink">Mon–Sat:</span> 11:00am – 9:00pm</li>
          <li><span class="font-medium text-ink">Sun &amp; public holidays:</span> Closed</li>
        </ul>

        <h3 class="mt-8 font-heading text-lg font-bold text-ink">Get in touch</h3>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex items-center gap-3">
            <dt class="font-semibold text-ink">Phone</dt>
            <dd><a href={phoneHref} class="text-azure hover:underline">{phoneDisplay}</a></dd>
          </div>
          <div class="flex items-center gap-3">
            <dt class="font-semibold text-ink">WhatsApp</dt>
            <dd>
              <a
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-azure hover:underline"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path
                    d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.099zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
                  ></path>
                </svg>
                {phoneDisplay}
              </a>
            </dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT — map -->
      <div class="min-h-[360px] overflow-hidden rounded-[var(--r-lg)] border border-line shadow-[var(--shadow-soft)]" data-reveal data-reveal-delay="1">
        <iframe
          title="Map — Rasheed Hospital, Main Boulevard, DHA Defence, Lahore"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-full min-h-[360px] w-full border-0"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>
