---
// Reusable alternating two-column service block (template for service pages).
// Panel is a DESIGNED GRAPHIC (no photography): gradient field + glow + rings +
// frosted icon disc + faint cross-mark motif. Icon comes via the `icon` slot.
interface Props {
  title: string;
  intro: string;
  relevantIf: string[];
  whatToExpect: string[];
  reversed?: boolean;
  id?: string;
}
const { title, intro, relevantIf, whatToExpect, reversed = false, id } = Astro.props;
---

<div class="service-block" data-slide={reversed ? "right" : "left"} id={id}>
  <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
    <!-- Designed graphic panel -->
    <div class={`sb-panel ${reversed ? "lg:order-last" : ""}`} data-reveal aria-hidden="true">
      <img class="sb-motif" src="/favicon.png" alt="" />
      <span class="sb-glow"></span>
      <span class="sb-ring sb-ring--outer"></span>
      <span class="sb-ring sb-ring--inner"></span>
      <span class="sb-disc">
        <span class="sb-icon text-azure">
          <slot name="icon" />
        </span>
      </span>
    </div>

    <!-- Content -->
    <div>
      <h2
        class="font-heading text-2xl font-extrabold tracking-tight text-ink sm:text-3xl"
        data-reveal
      >
        {title}
      </h2>
      <p class="mt-4 measure-tight text-base leading-relaxed text-body" data-reveal>
        {intro}
      </p>

      <div class="mt-7 grid gap-7 sm:grid-cols-2">
        <div>
          <h3 class="eyebrow" data-reveal>This may be relevant if</h3>
          <ul class="mt-4 space-y-2.5">
            {
              relevantIf.map((item) => (
                <li class="flex items-start gap-2.5" data-reveal>
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-azure/12 text-azure">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12l5 5l9 -9" />
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed text-body">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="eyebrow" data-reveal>What to expect</h3>
          <ul class="mt-4 space-y-2.5">
            {
              whatToExpect.map((item) => (
                <li class="flex items-start gap-2.5" data-reveal>
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-sky/20 text-navy">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12l5 5l9 -9" />
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed text-body">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .sb-panel {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    background: linear-gradient(150deg, #ffffff 0%, var(--ice) 45%, #e2effd 100%);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition:
      transform 0.4s ease,
      box-shadow 0.4s ease;
  }

  /* Faint cross-mark motif, fully composed within the panel. */
  .sb-motif {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 76%;
    height: 76%;
    object-fit: contain;
    opacity: 0.045;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  .sb-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 56%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    z-index: 1;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--sky) 60%, transparent) 0%,
      transparent 68%
    );
    filter: blur(22px);
    opacity: 0.55;
    transition: opacity 0.45s ease;
    animation: sb-pulse 7s ease-in-out infinite;
  }
  @keyframes sb-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.68; }
  }

  .sb-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 9999px;
    transform: translate(-50%, -50%);
    z-index: 2;
    transition: transform 0.45s ease;
  }
  .sb-ring--outer {
    width: 64%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--azure) 24%, transparent);
  }
  .sb-ring--inner {
    width: 46%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--sky) 50%, transparent);
  }

  .sb-disc {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34%;
    aspect-ratio: 1;
    border-radius: 9999px;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(228, 240, 253, 0.78));
    border: 1px solid color-mix(in srgb, var(--azure) 18%, transparent);
    box-shadow: 0 10px 24px -14px color-mix(in srgb, var(--navy) 40%, transparent);
    backdrop-filter: blur(4px);
  }
  .sb-icon {
    display: flex;
    transition: transform 0.45s ease;
  }
  .sb-icon :global(svg) {
    width: 46%;
    min-width: 2.6rem;
    height: auto;
    aspect-ratio: 1;
    stroke-width: 1.5;
  }

  /* Premium hover — desktop / fine-pointer / motion-OK only. */
  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .sb-panel:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lift);
    }
    .sb-panel:hover .sb-glow {
      opacity: 0.85;
    }
    .sb-panel:hover .sb-icon {
      transform: scale(1.05);
    }
    .sb-panel:hover .sb-ring--outer {
      transform: translate(-50%, -50%) scale(1.06);
    }
    .sb-panel:hover .sb-ring--inner {
      transform: translate(-50%, -50%) scale(1.09);
    }
  }
</style>

<script>
  // Subtle side-slide for each block as it enters (x only — never opacity —
  // so a failure can't hide content; the panel + items reveal via the global
  // [data-reveal] batch). Runs once per page; isolated in try/catch.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  try {
    gsap.registerPlugin(ScrollTrigger);
    if (!prefersReducedMotion()) {
      const blocks = gsap.utils.toArray<HTMLElement>("[data-slide]");
      blocks.forEach((b) => {
        const dir = b.getAttribute("data-slide") === "right" ? 1 : -1;
        gsap.from(b, {
          xPercent: dir * 5,
          duration: 0.7,
          ease: EASE,
          scrollTrigger: { trigger: b, start: "top 80%" },
        });
      });
    }
  } catch (err) {
    console.error("[service-block] slide-in failed (non-fatal)", err);
  }
</script>
