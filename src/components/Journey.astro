---
const whatsappHref = "https://wa.me/923148432789";

const steps = [
  {
    label: "Step 01",
    icon: "message",
    title: "Reach out when you're ready",
    body: "A message on WhatsApp — no forms to fill, no waiting rooms. We usually reply the same day, and there's no obligation to book anything.",
  },
  {
    label: "Step 02",
    icon: "stethoscope",
    title: "An unhurried first consultation",
    body: "A conversation, not a checklist. We take time to understand your history, your hopes, and any reports or tests you already have.",
  },
  {
    label: "Step 03",
    icon: "clipboard",
    title: "Understand your options, honestly",
    body: "We explain what's medically known, what's worth investigating, and what isn't — in plain language, with the benefits and limits of each path laid out clearly.",
  },
  {
    label: "Step 04",
    icon: "route",
    title: "A plan that's yours",
    body: "A clear, written plan built around your timeline and your values, with sensible next steps. You set the pace from here, and nothing moves without your say.",
  },
];

const num = (i: number) => String(i + 1).padStart(2, "0");
---

<!-- Soft white→ice (begins at Consultations' base #FFFFFF, ends #F4F9FE). -->
<section
  class="journey relative py-20 md:py-28"
  data-journey
  style="background: linear-gradient(to bottom, #FFFFFF 0, #F4F9FE 100%);"
>
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <!-- Header -->
    <div class="text-center">
      <p class="eyebrow" data-reveal>Your journey with us</p>
      <h2 class="mt-3 t-h2 text-ink" data-reveal data-reveal-delay="1">
        From first message to <span class="text-azure">a plan that's yours</span>
      </h2>
      <p class="mx-auto mt-5 measure text-base text-body [margin-inline:auto]" data-reveal data-reveal-delay="2">
        No forms, no waiting rooms, no pressure. Here's exactly what happens from
        the moment you reach out — at a pace that respects your time and your
        decisions.
      </p>
    </div>

    <!-- Vertical timeline -->
    <ol class="timeline relative mt-16" style="--rail: 24px;">
      <!-- Rail: light track + scrubbed gradient fill -->
      <div class="j-track" aria-hidden="true"></div>
      <div class="j-fill" aria-hidden="true"></div>

      {
        steps.map((step, i) => (
          <li class="relative flex items-start gap-5 pb-12 last:pb-0">
            <span class="j-marker relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full font-heading text-base font-bold text-white">
              {num(i)}
            </span>

            <div class="j-card flex-1 rounded-[var(--r-lg)] border border-line bg-white p-6 shadow-[var(--shadow-soft)] sm:p-7">
              <div class="flex items-center gap-2.5">
                <span class="text-azure">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {step.icon === "message" && (
                      <>
                        <path d="M3 20l1.3 -3.9a9 8 0 1 1 3.4 2.9l-4.7 1" />
                        <path d="M8 12v.01" />
                        <path d="M12 12v.01" />
                        <path d="M16 12v.01" />
                      </>
                    )}
                    {step.icon === "stethoscope" && (
                      <>
                        <path d="M6 4h-1a1 1 0 0 0 -1 1v3.5a5.5 5.5 0 0 0 11 0v-3.5a1 1 0 0 0 -1 -1h-1" />
                        <path d="M8 15a6 6 0 1 0 12 0v-3" />
                        <path d="M20 9m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
                      </>
                    )}
                    {step.icon === "clipboard" && (
                      <>
                        <path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2" />
                        <path d="M9 3m0 2a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v0a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2z" />
                        <path d="M9 14l2 2l4 -4" />
                      </>
                    )}
                    {step.icon === "route" && (
                      <>
                        <path d="M3 17a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                        <path d="M17 7a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                        <path d="M11 19h5.5a3.5 3.5 0 0 0 0 -7h-8a3.5 3.5 0 0 1 0 -7h4.5" />
                      </>
                    )}
                  </svg>
                </span>
                <span class="eyebrow">{step.label}</span>
              </div>

              <h3 class="mt-3 font-heading text-lg font-bold text-ink">
                {step.title}
              </h3>
              <p class="mt-2 measure-tight text-sm leading-relaxed text-body">
                {step.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>

    <!-- Closing CTA -->
    <div class="mt-14 text-center" data-reveal>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-azure to-navy px-8 py-4 text-base font-semibold text-white shadow-[var(--shadow-soft)] transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]"
      >
        Start with a message
      </a>
      <p class="mt-4 text-sm text-body">
        Message us on WhatsApp — we usually reply the same day, with no obligation.
      </p>
    </div>
  </div>
</section>

<style>
  /* Rail position is anchored to the marker centre (--rail = half marker w). */
  .j-track,
  .j-fill {
    position: absolute;
    top: 0.75rem;
    bottom: 3.75rem;
    left: var(--rail);
    width: 3px;
    transform: translateX(-50%);
    border-radius: 9999px;
  }
  .j-track {
    background: var(--line);
  }
  .j-fill {
    background: linear-gradient(to bottom, var(--sky), var(--azure) 55%, var(--navy));
    transform: translateX(-50%) scaleY(1); /* default full (no-JS / reduced) */
    transform-origin: top;
  }

  /* Marker default = ACTIVE (so reduced motion / no-JS shows it lit). */
  .j-marker {
    background: linear-gradient(135deg, var(--azure), var(--navy));
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--azure) 16%, transparent);
  }
  .j-marker::after {
    content: "";
    position: absolute;
    inset: -5px;
    border-radius: 9999px;
    border: 1.5px solid color-mix(in srgb, var(--sky) 55%, transparent);
    animation: j-pulse 3s ease-in-out infinite;
  }
  @keyframes j-pulse {
    0%, 100% { transform: scale(1); opacity: 0.55; }
    50% { transform: scale(1.12); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .j-fill { transform: translateX(-50%) scaleY(1); }
    .j-marker::after { animation: none; }
  }
</style>

<script>
  // Scroll-scrubbed journey timeline. Fully isolated in try/catch — a failure
  // here must never block the global [data-reveal] reveal system or blank the
  // page. Cards/markers default to their visible/active state in CSS, so even
  // total script failure leaves the section readable.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  try {
    gsap.registerPlugin(ScrollTrigger);
    const section = document.querySelector<HTMLElement>("[data-journey]");

    if (section && !prefersReducedMotion()) {
      const fill = section.querySelector<HTMLElement>(".j-fill");
      const markers = gsap.utils.toArray<HTMLElement>(section.querySelectorAll(".j-marker"));
      const cards = gsap.utils.toArray<HTMLElement>(section.querySelectorAll(".j-card"));

      // Dim start state (markers idle, cards hidden, line empty).
      if (fill) gsap.set(fill, { scaleY: 0 });
      gsap.set(markers, { opacity: 0.4, scale: 0.82, transformOrigin: "center" });
      gsap.set(cards, { opacity: 0, y: 16 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          end: "bottom 75%",
          scrub: true,
        },
      });

      if (fill) tl.to(fill, { scaleY: 1, ease: "none", duration: 1 }, 0);

      markers.forEach((m, i) => {
        const at = i * 0.26;
        tl.to(m, { opacity: 1, scale: 1, duration: 0.16, ease: EASE }, at);
        if (cards[i]) tl.to(cards[i], { opacity: 1, y: 0, duration: 0.22, ease: EASE }, at + 0.03);
      });
    }
  } catch (err) {
    console.error("[journey] timeline animation failed — showing static section", err);
    // Safety: reveal everything this section controls.
    const section = document.querySelector<HTMLElement>("[data-journey]");
    section?.querySelectorAll<HTMLElement>(".j-card, .j-marker").forEach((el) => {
      el.style.opacity = "1";
      el.style.transform = "none";
    });
    const fill = section?.querySelector<HTMLElement>(".j-fill");
    if (fill) fill.style.transform = "translateX(-50%) scaleY(1)";
  }
</script>
