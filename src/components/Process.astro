---
const steps = [
  {
    title: "Book online",
    body: "Choose a consultation type and time in our secure calendar. You'll see the full fee before confirming.",
  },
  {
    title: "Share your history",
    body: "Before or during your appointment we ask about your history, fertility journey, medications, and goals — respectfully and inclusively.",
  },
  {
    title: "Consultation & plan",
    body: "Your doctor reviews your concerns, explains what's medically known, and agrees a stepwise plan: tests, lifestyle changes, or referral.",
  },
  {
    title: "Summary & follow-up",
    body: "You receive a clear written summary and agreed next steps. Follow-ups can be booked as needed.",
  },
];

const num = (i: number) => String(i + 1).padStart(2, "0");
---

<!-- Gradient bleed: begins at the Consultations base (#FFFFFF) -->
<section
  class="proc relative overflow-hidden py-20 md:py-28"
  data-proc
  style="background: linear-gradient(to bottom, #FFFFFF 0, #F4F9FE 280px);"
>
  <!-- Ambient drift (very faint) -->
  <span class="proc-blob proc-blob--a" aria-hidden="true"></span>
  <span class="proc-blob proc-blob--b" aria-hidden="true"></span>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow" data-reveal>What to expect</p>
      <h2 class="mt-3 t-h2 text-ink" data-reveal data-reveal-delay="1">
        A clear path, paced to keep you in control
      </h2>
    </div>

    <div class="mt-16">
      <!-- ── Desktop / tablet: horizontal row ───────────────── -->
      <div class="relative hidden md:block" data-proc-track="h">
        <div class="absolute left-[12.5%] right-[12.5%] top-[28px] h-[3px] -translate-y-1/2 rounded-full bg-line"></div>
        <div class="fill-h absolute left-[12.5%] right-[12.5%] top-[28px] h-[3px] -translate-y-1/2 rounded-full bg-gradient-to-r from-sky to-azure"></div>

        <ol class="relative grid grid-cols-2 gap-x-8 gap-y-12 lg:grid-cols-4">
          {
            steps.map((step, i) => (
              <li class="proc-step flex flex-col items-center text-center">
                <span class="marker flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-azure to-navy font-heading text-lg font-bold text-white shadow-[var(--shadow-soft)]">
                  {num(i)}
                </span>
                <div class="proc-text">
                  <h3 class="mt-5 font-heading text-base font-bold text-ink">
                    {step.title}
                  </h3>
                  <p class="mt-2 max-w-[15rem] text-sm leading-relaxed text-body">
                    {step.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- ── Mobile: vertical stack with vertical line ──────── -->
      <div class="relative md:hidden" data-proc-track="v">
        <div class="absolute bottom-7 left-7 top-7 w-[3px] -translate-x-1/2 rounded-full bg-line"></div>
        <div class="fill-v absolute bottom-7 left-7 top-7 w-[3px] -translate-x-1/2 rounded-full bg-gradient-to-b from-sky to-azure"></div>

        <ol class="relative space-y-9">
          {
            steps.map((step, i) => (
              <li class="proc-step flex items-start gap-5">
                <span class="marker flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-azure to-navy font-heading text-lg font-bold text-white shadow-[var(--shadow-soft)]">
                  {num(i)}
                </span>
                <div class="proc-text pt-1">
                  <h3 class="font-heading text-base font-bold text-ink">
                    {step.title}
                  </h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-body">
                    {step.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  /* Faint ambient blobs — carries the hero's living quality down the page */
  .proc-blob {
    position: absolute;
    z-index: 0;
    border-radius: 9999px;
    filter: blur(80px);
    pointer-events: none;
  }
  .proc-blob--a {
    width: 30rem;
    height: 30rem;
    top: -6rem;
    right: -8rem;
    background: radial-gradient(circle, var(--sky), transparent 70%);
    opacity: 0.18;
    animation: proc-drift-a 30s ease-in-out infinite;
  }
  .proc-blob--b {
    width: 26rem;
    height: 26rem;
    bottom: -8rem;
    left: -7rem;
    background: radial-gradient(circle, var(--azure), transparent 70%);
    opacity: 0.12;
    animation: proc-drift-b 36s ease-in-out infinite;
  }
  @keyframes proc-drift-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-36px, 26px) scale(1.06); }
  }
  @keyframes proc-drift-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -24px) scale(1.04); }
  }

  /* Fill lines grow from the start of the path. Default = full (no-JS state). */
  .fill-h { transform: scaleX(1); transform-origin: left; }
  .fill-v { transform: scaleY(1); transform-origin: top; }

  /* DEFAULT (no-JS / reduced motion) = final state: markers active, text shown.
     The GSAP scrub (script below) sets the dim start state and animates. */
  @media (prefers-reduced-motion: reduce) {
    .fill-h { transform: scaleX(1); }
    .fill-v { transform: scaleY(1); }
    .marker { opacity: 1; }
    .proc-text { opacity: 1; }
  }
</style>

<script>
  // Scroll-scrubbed stepper — the line fills and markers ignite in sync with
  // scroll position (not a one-shot). Uses the shared easing.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>("[data-proc]");

  if (section && !prefersReducedMotion()) {
    const mm = gsap.matchMedia();

    const build = (
      selector: string,
      fillSel: string,
      axis: "scaleX" | "scaleY",
    ) => {
      const track = section.querySelector<HTMLElement>(selector);
      if (!track) return;
      const fill = track.querySelector<HTMLElement>(fillSel);
      const markers = gsap.utils.toArray<HTMLElement>(
        track.querySelectorAll(".marker"),
      );
      const texts = gsap.utils.toArray<HTMLElement>(
        track.querySelectorAll(".proc-text"),
      );

      // Dim start state.
      gsap.set(fill, { [axis]: 0 });
      gsap.set(markers, { opacity: 0.4, scale: 0.82, transformOrigin: "center" });
      gsap.set(texts, { opacity: 0, y: 12 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 70%",
          end: "bottom 70%",
          scrub: true,
        },
      });

      // Fill spans the whole timeline (linear with scrub).
      tl.to(fill, { [axis]: 1, ease: "none", duration: 1 }, 0);

      // Each marker ignites + its text fades up as the fill reaches it.
      markers.forEach((m, i) => {
        const at = i * 0.26;
        tl.to(m, { opacity: 1, scale: 1, duration: 0.18, ease: EASE }, at);
        if (texts[i])
          tl.to(texts[i], { opacity: 1, y: 0, duration: 0.2, ease: EASE }, at + 0.04);
      });
    };

    mm.add("(min-width: 768px)", () =>
      build('[data-proc-track="h"]', ".fill-h", "scaleX"),
    );
    mm.add("(max-width: 767px)", () =>
      build('[data-proc-track="v"]', ".fill-v", "scaleY"),
    );
  }
</script>
