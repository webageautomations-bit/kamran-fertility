---
const faqs = [
  {
    q: "Do I need a confirmed diagnosis before booking?",
    a: "No. Many patients come in with questions, concerns, or previous reports. The consultation helps us understand your situation and explain appropriate next steps.",
  },
  {
    q: "What happens during the first consultation?",
    a: "Dr. Kamran Saleem reviews your medical history, listens to your concerns, and discusses any prior tests. Options are explained clearly, with recommendations only when medically appropriate.",
  },
  {
    q: "Do you recommend tests or treatments for everyone?",
    a: "No. Tests and treatments are recommended only when they're likely to provide useful information or benefit your care.",
  },
  {
    q: "Do you offer second opinions on previous treatments?",
    a: "Yes. We regularly review prior recommendations and help you understand your options moving forward.",
  },
];
---

<!-- Gradient bleed: begins at the Testimonials base (#FFFFFF) -->
<section
  class="relative py-20 md:py-28"
  style="background: linear-gradient(to bottom, #FFFFFF 0, #F4F9FE 280px);"
>
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow" data-reveal>Still not sure?</p>
      <h2 class="mt-3 t-h2 text-ink" data-reveal data-reveal-delay="1">
        Frequently asked questions
      </h2>
    </div>

    <!-- Accordion -->
    <div class="mt-12 space-y-4" data-faq>
      {
        faqs.map((item, i) => (
          <div
            class="overflow-hidden rounded-[var(--r-md)] border border-line bg-white transition-colors duration-300 hover:border-azure/40"
            data-reveal
            data-reveal-delay={i + 1}
          >
            <h3>
              <button
                type="button"
                class="faq-trigger flex w-full items-center justify-between gap-4 px-5 py-5 text-left sm:px-6"
                aria-expanded="false"
                aria-controls={`faq-panel-${i}`}
                id={`faq-trigger-${i}`}
              >
                <span class="font-heading text-base font-bold text-ink">
                  {item.q}
                </span>
                <svg
                  class="faq-chevron h-5 w-5 shrink-0 text-azure"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M6 9l6 6l6 -6" />
                </svg>
              </button>
            </h3>
            <div
              id={`faq-panel-${i}`}
              role="region"
              aria-labelledby={`faq-trigger-${i}`}
              class="faq-panel"
            >
              <p class="faq-answer px-5 pb-5 text-sm leading-relaxed text-body sm:px-6">
                {item.a}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Collapsed by default; GSAP animates height/opacity (or sets instantly
     under reduced motion). */
  .faq-panel {
    height: 0;
    overflow: hidden;
  }
  .faq-answer {
    opacity: 0;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { EASE, prefersReducedMotion } from "../scripts/motion";

  const root = document.querySelector<HTMLElement>("[data-faq]");
  if (root) {
    const reduce = prefersReducedMotion();
    const triggers = Array.from(
      root.querySelectorAll<HTMLButtonElement>(".faq-trigger"),
    );

    const panelOf = (btn: HTMLButtonElement) =>
      document.getElementById(btn.getAttribute("aria-controls") || "");
    const chevronOf = (btn: HTMLButtonElement) =>
      btn.querySelector<SVGElement>(".faq-chevron");
    const answerOf = (panel: HTMLElement | null) =>
      panel?.querySelector<HTMLElement>(".faq-answer") ?? null;

    const close = (btn: HTMLButtonElement) => {
      if (btn.getAttribute("aria-expanded") !== "true") return;
      btn.setAttribute("aria-expanded", "false");
      const panel = panelOf(btn);
      const chevron = chevronOf(btn);
      const answer = answerOf(panel);
      if (reduce) {
        if (panel) panel.style.height = "0px";
        if (answer) gsap.set(answer, { opacity: 0 });
        if (chevron) gsap.set(chevron, { rotation: 0 });
        return;
      }
      if (answer) gsap.to(answer, { opacity: 0, y: 8, duration: 0.25, ease: EASE });
      if (panel) gsap.to(panel, { height: 0, duration: 0.4, ease: EASE });
      if (chevron) gsap.to(chevron, { rotation: 0, duration: 0.4, ease: "back.out(2)" });
    };

    const open = (btn: HTMLButtonElement) => {
      btn.setAttribute("aria-expanded", "true");
      const panel = panelOf(btn);
      const chevron = chevronOf(btn);
      const answer = answerOf(panel);
      if (reduce) {
        if (panel) panel.style.height = "auto";
        if (answer) gsap.set(answer, { opacity: 1, y: 0 });
        if (chevron) gsap.set(chevron, { rotation: 180 });
        return;
      }
      if (panel) gsap.to(panel, { height: "auto", duration: 0.42, ease: EASE });
      if (answer)
        gsap.fromTo(
          answer,
          { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.4, ease: EASE, delay: 0.08 },
        );
      if (chevron)
        gsap.to(chevron, { rotation: 180, duration: 0.5, ease: "back.out(2)" });
    };

    triggers.forEach((btn) => {
      btn.addEventListener("click", () => {
        const isOpen = btn.getAttribute("aria-expanded") === "true";
        triggers.forEach((other) => other !== btn && close(other));
        isOpen ? close(btn) : open(btn);
      });
    });
  }
</script>
