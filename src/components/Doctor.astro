---
const whatsappHref = "https://wa.me/923148432789";

const credentials = [
  "MBBS — Bachelor of Medicine, Bachelor of Surgery",
  "Dip GUM & Ven (UK) — Diploma in Genitourinary Medicine and Venereology",
  "Clinical experience in fertility assessment and reproductive health",
  "Expertise in male and female fertility concerns",
  "Focus on men's health, urinary tract infections, and STDs",
  "Experience with IVF, IUI, and assisted fertility treatment planning",
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-white to-ice py-20 md:py-28">
  <!-- Oversized faint monogram — brand texture filling the no-photography gap. -->
  <span class="doc-monogram" aria-hidden="true">K</span>

  <div class="relative z-10 mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[42fr_58fr] lg:gap-16">
    <!-- LEFT — portrait (first on mobile too) -->
    <div data-reveal>
      <div class="doctor-panel">
        <span class="d-glow" aria-hidden="true"></span>
        <span class="d-ring" aria-hidden="true"></span>
        <!-- Pedestal: soft ground + contact shadow -->
        <span class="d-pedestal" aria-hidden="true"></span>
        <img
          src="/assets/dr-kamran.webp"
          alt="Dr. Kamran Saleem"
          width="800"
          height="1104"
          class="d-photo"
          loading="lazy"
        />
      </div>
    </div>

    <!-- RIGHT — bio + credentials -->
    <div class="reveal-up" data-reveal style="--d:140ms">
      <p class="eyebrow">
        Meet the doctor
      </p>
      <h2 class="mt-3 t-h2 text-ink">
        Dr. Kamran Saleem
      </h2>
      <p class="mt-6 text-base leading-relaxed text-body">
        Dr. Kamran Saleem is a dedicated fertility specialist who believes that
        effective care begins with listening. With years of focused experience
        in reproductive health, he takes a thoughtful, patient-centered approach
        — ensuring every consultation is clear, respectful, and guided by medical
        evidence.
      </p>

      <h3 class="mt-8 font-heading text-lg font-bold text-ink">
        Qualifications & expertise
      </h3>
      <ul class="mt-5 grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2" data-stagger>
        {
          credentials.map((c) => (
            <li class="flex items-start gap-3" data-reveal>
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-azure/12 text-azure">
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12l5 5l9 -9" />
                </svg>
              </span>
              <span class="text-sm leading-relaxed text-body">{c}</span>
            </li>
          ))
        }
      </ul>

      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        class="mt-9 inline-flex items-center justify-center rounded-full bg-gradient-to-r from-azure to-navy px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-azure/25 transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-azure/40"
      >
        Book a consultation
      </a>
    </div>
  </div>
</section>

<style>
  /* Calm, simpler echo of the hero stage — no animation. */
  .doctor-panel {
    position: relative;
    margin-inline: auto;
    width: 100%;
    max-width: 24rem;
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    border-radius: 1.5rem;
    background: linear-gradient(180deg, #ffffff, var(--ice));
    border: 1px solid var(--line);
    /* No overflow:hidden — the portrait's head must never be clipped. */
  }
  .d-glow {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 78%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--sky) 50%, transparent) 0%,
      transparent 65%
    );
    filter: blur(20px);
    opacity: 0.7;
  }
  .d-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 86%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--azure) 30%, transparent);
  }
  /* Pedestal — soft ground disc + tighter contact shadow (echoes the hero). */
  .d-pedestal {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 84%;
    height: 36%;
    z-index: 1;
    border-radius: 9999px;
    background: radial-gradient(
      ellipse at center 60%,
      color-mix(in srgb, var(--sky) 34%, transparent),
      transparent 70%
    );
    filter: blur(10px);
  }
  .d-pedestal::after {
    content: "";
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    width: 56%;
    height: 15%;
    border-radius: 9999px;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--navy) 22%, transparent),
      transparent 72%
    );
    filter: blur(7px);
  }
  .d-photo {
    position: relative;
    z-index: 2;
    width: 90%;
    height: auto;
    object-fit: contain;
    /* Bottom-edge dissolve — head/torso stay sharp, only the hem fades. */
    -webkit-mask-image: linear-gradient(to bottom, #000 80%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 80%, transparent 100%);
  }

  /* Oversized faint monogram behind the portrait, clipped to the section. */
  .doc-monogram {
    position: absolute;
    z-index: 0;
    top: 50%;
    left: -2rem;
    transform: translateY(-50%);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(20rem, 38vw, 40rem);
    line-height: 0.8;
    color: var(--azure);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }
</style>
