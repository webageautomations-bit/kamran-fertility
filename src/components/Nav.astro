---
const services = [
  { label: "Assessment & Diagnosis", href: "/services/assessment" },
  { label: "Fertility Treatments", href: "/services/treatments" },
  { label: "Support & Second Opinions", href: "/services/support" },
];

const links = [
  { label: "Home", href: "/" },
  { label: "Resources", href: "/resources" },
  { label: "Contact", href: "/contact" },
];

const whatsappHref = "https://wa.me/923148432789";

// Active-state detection (normalise trailing slash).
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isCurrent = (href: string) =>
  (href.replace(/\/+$/, "") || "/") === currentPath;
const servicesOpen = currentPath.startsWith("/services");
---

<header
  class="sticky top-0 z-50 w-full border-b border-line bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80"
>
  <nav
    class="mx-auto flex h-[68px] max-w-7xl items-center justify-between gap-4 px-5 sm:px-8"
    aria-label="Primary"
  >
    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center" aria-label="Dr. Kamran Saleem — home">
      <img
        src="/assets/logo.webp"
        alt="Dr. Kamran Saleem fertility clinic"
        width="640"
        height="215"
        class="h-[50px] w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 lg:flex">
      <li>
        <a href="/" class="nav-link">Home</a>
      </li>

      <!-- Services dropdown -->
      <li class="group relative">
        <button
          type="button"
          class="nav-link inline-flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
          data-services-trigger
        >
          Services
          <svg
            class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180"
            viewBox="0 0 12 12"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 4.5 6 7.5 9 4.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div
          class="invisible absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 translate-y-1 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
        >
          <div
            class="overflow-hidden rounded-[var(--r-md)] border border-line bg-white p-2 shadow-[var(--shadow-soft)]"
          >
            {
              services.map((s) => (
                <a
                  href={s.href}
                  class="block rounded-[var(--r-sm)] px-4 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-ice hover:text-azure"
                >
                  {s.label}
                </a>
              ))
            }
          </div>
        </div>
      </li>

      <li>
        <a href="/resources" class="nav-link">Resources</a>
      </li>
      <li>
        <a href="/contact" class="nav-link">Contact</a>
      </li>
    </ul>

    <!-- Right: CTA + mobile toggle -->
    <div class="flex items-center gap-3">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-gradient-to-r from-azure to-navy px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-azure/20 transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-azure/30 sm:inline-flex"
      >
        Book consultation
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-ink transition-colors hover:bg-ice lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <svg class="menu-open h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
        <svg class="menu-close hidden h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-line bg-white lg:hidden" data-mobile-menu>
    <div class="space-y-1 px-5 py-4">
      <a href="/" class="m-item" data-menu-link aria-current={isCurrent("/") ? "page" : undefined}>
        <span>Home</span>
      </a>

      <!-- Services: same styling as other items; toggles an inline accordion. -->
      <button
        type="button"
        class="m-item"
        aria-expanded={servicesOpen ? "true" : "false"}
        aria-controls="m-services"
        data-services-toggle
      >
        <span>Services</span>
        <svg class="m-chevron h-4 w-4 text-body" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6l6 -6" />
        </svg>
      </button>
      <div id="m-services" class={`m-sub ${servicesOpen ? "open" : ""}`} data-services-panel>
        <div class="m-sub-inner">
          {
            services.map((s) => (
              <a
                href={s.href}
                class="m-sublink"
                data-menu-link
                aria-current={isCurrent(s.href) ? "page" : undefined}
              >
                {s.label}
              </a>
            ))
          }
        </div>
      </div>

      <a href="/resources" class="m-item" data-menu-link aria-current={isCurrent("/resources") ? "page" : undefined}>
        <span>Resources</span>
      </a>
      <a href="/contact" class="m-item" data-menu-link aria-current={isCurrent("/contact") ? "page" : undefined}>
        <span>Contact</span>
      </a>

      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        data-menu-link
        class="mt-3 block rounded-full bg-gradient-to-r from-azure to-navy px-5 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-azure/20"
      >
        Book consultation
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--azure), var(--navy));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-link:hover {
    color: var(--azure);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* ── Mobile menu ─────────────────────────────────────────── */
  /* Uniform top-level item (Home, Services, Resources, Contact). */
  .m-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    min-height: 44px;
    border-radius: 0.5rem;
    padding: 0.625rem 0.75rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    text-align: left;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
  .m-item:hover {
    background: var(--ice);
  }
  /* Tap feedback + current page */
  .m-item:active {
    background: var(--ice);
    color: var(--azure);
  }
  .m-item[aria-current="page"] {
    background: var(--ice);
    color: var(--azure);
  }
  /* Services parent reads as active when on a /services/* page */
  .m-item[aria-expanded="true"] .m-chevron {
    transform: rotate(180deg);
  }
  .m-chevron {
    transition: transform 0.3s ease;
    flex: none;
  }

  /* Accordion: smooth height via grid-template-rows (0fr ↔ 1fr). */
  .m-sub {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .m-sub.open {
    grid-template-rows: 1fr;
  }
  .m-sub-inner {
    overflow: hidden;
    min-height: 0;
  }

  /* Indented sub-links */
  .m-sublink {
    display: flex;
    align-items: center;
    min-height: 44px;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem 0.5rem 2rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--body-text);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
  .m-sublink:hover {
    background: var(--ice);
  }
  .m-sublink:active {
    background: var(--ice);
    color: var(--azure);
  }
  .m-sublink[aria-current="page"] {
    background: var(--ice);
    color: var(--azure);
  }

  @media (prefers-reduced-motion: reduce) {
    .m-sub {
      transition: none;
    }
    .m-chevron {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const openIcon = toggle?.querySelector<SVGElement>(".menu-open");
  const closeIcon = toggle?.querySelector<SVGElement>(".menu-close");
  const servicesToggle = document.querySelector<HTMLButtonElement>("[data-services-toggle]");
  const servicesPanel = document.querySelector<HTMLElement>("[data-services-panel]");

  const collapseServices = () => {
    servicesPanel?.classList.remove("open");
    servicesToggle?.setAttribute("aria-expanded", "false");
  };

  const setMenu = (open: boolean) => {
    menu?.classList.toggle("hidden", !open);
    toggle?.setAttribute("aria-expanded", String(open));
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
    // Closing the menu resets the Services accordion to collapsed.
    if (!open) collapseServices();
  };

  toggle?.addEventListener("click", () =>
    setMenu(menu?.classList.contains("hidden") ?? true),
  );

  // Services row expands/collapses inline — it never navigates.
  servicesToggle?.addEventListener("click", () => {
    const open = servicesToggle.getAttribute("aria-expanded") === "true";
    servicesToggle.setAttribute("aria-expanded", String(!open));
    servicesPanel?.classList.toggle("open", !open);
  });

  // Any navigating link (top items, sub-links, CTA) closes the menu.
  document.querySelectorAll<HTMLAnchorElement>("[data-menu-link]").forEach((l) =>
    l.addEventListener("click", () => setMenu(false)),
  );
</script>
