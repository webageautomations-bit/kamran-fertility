---
// Self-hosted variable fonts (Fontsource)
import "@fontsource-variable/plus-jakarta-sans";
import "@fontsource-variable/inter";
import "../styles/global.css";

import BaseHead from "../components/BaseHead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Dr. Kamran Saleem — Doctor-led fertility care in Lahore",
  description = "Unhurried, evidence-based fertility consultations with Dr. Kamran Saleem in Lahore. Honest answers, clear options, and a plan built around your timeline and your values.",
  image,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <!-- FOUC guard (runs before first paint): drop .no-js so .fouc headlines
         start hidden when JS is on; if the headline animation never starts,
         force-reveal them so the headline can never stay blank. -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.remove("no-js");
        d.classList.add("js");

        // FOUC safety net: if the headline animation never starts, reveal it.
        window.setTimeout(function () {
          if (window.__fouc) return;
          var els = document.querySelectorAll(".fouc");
          for (var i = 0; i < els.length; i++) els[i].style.opacity = "1";
        }, 1200);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-white text-body antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- SAFETY NET (inline, NOT bundled): runs even if the motion module below
         fails to load/parse. Marks JS alive (enables the CSS reveal start-state)
         and, if the module never signals readiness, force-reveals everything so
         the page can never present blank. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var reduce =
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        // Only opt into the hidden start-state when motion is allowed.
        if (!reduce) root.classList.add("motion-js");
        // Fallback: if the motion module hasn't taken over shortly, reveal all.
        window.setTimeout(function () {
          if (window.__motionReady) return;
          var els = document.querySelectorAll("[data-reveal], [data-reveal-onload]");
          for (var i = 0; i < els.length; i++) {
            els[i].style.opacity = "1";
            els[i].style.transform = "none";
          }
        }, 2000);
      })();
    </script>

    <script>
      // ── Site motion engine: Lenis smooth scroll + GSAP ScrollTrigger ──────
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";
      import { EASE, DURATION, STAGGER, prefersReducedMotion } from "../scripts/motion";

      gsap.registerPlugin(ScrollTrigger, SplitText);

      const reveals = gsap.utils.toArray<HTMLElement>("[data-reveal]");
      const onloads = gsap.utils.toArray<HTMLElement>("[data-reveal-onload]");
      const showAll = () =>
        [...reveals, ...onloads].forEach((el) => gsap.set(el, { opacity: 1, y: 0 }));

      // ── Content reveal FIRST, and isolated from everything else. Un-hiding
      //    the page is the priority; nothing below may prevent it. ──
      try {
        if (prefersReducedMotion()) {
          showAll();
        } else {
          gsap.set([...reveals, ...onloads], { opacity: 0, y: 26 });

          // Scroll-reveal for below-the-fold content. start "top 90%" → a
          // section animates as its top edge enters the viewport, not after.
          ScrollTrigger.batch("[data-reveal]", {
            start: "top 90%",
            onEnter: (batch) =>
              gsap.to(batch, {
                opacity: 1,
                y: 0,
                duration: DURATION,
                ease: EASE,
                stagger: STAGGER,
                overwrite: true,
              }),
          });

          // Above-the-fold hero entrance: reveal on LOAD, never scroll-gated.
          if (onloads.length) {
            gsap.to(onloads, {
              opacity: 1,
              y: 0,
              duration: DURATION,
              ease: EASE,
              stagger: STAGGER,
              delay: 0.05,
              overwrite: true,
            });
          }

          // Keep trigger positions accurate on mobile: recompute after the
          // initial layout, after fonts swap, on resize, and on rotate.
          const refresh = () => ScrollTrigger.refresh();
          refresh();
          window.addEventListener("load", refresh);
          window.addEventListener("orientationchange", () =>
            window.setTimeout(refresh, 250),
          );
          if (document.fonts?.ready) document.fonts.ready.then(refresh);
          let rt: number;
          window.addEventListener("resize", () => {
            window.clearTimeout(rt);
            rt = window.setTimeout(refresh, 200);
          });
        }
      } catch (err) {
        console.error("[motion] reveal init failed — revealing all content", err);
        showAll();
      } finally {
        // Tell the inline safety net the module took over (success or handled).
        (window as any).__motionReady = true;
      }

      // ── Smooth scroll is a separate enhancement. If Lenis throws, the page
      //    is already revealed above; we just fall back to native scroll. ──
      if (!prefersReducedMotion()) {
        try {
          const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
          lenis.on("scroll", ScrollTrigger.update);
          gsap.ticker.add((t) => lenis.raf(t * 1000));
          gsap.ticker.lagSmoothing(0);
          (window as any).__lenis = lenis;
        } catch (err) {
          console.error("[motion] Lenis init failed — using native scroll", err);
        }
      }
    </script>
  </body>
</html>
